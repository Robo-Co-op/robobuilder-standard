#!/usr/bin/env bash
set -euo pipefail

limit=20
query=""
while [ $# -gt 0 ]; do
  case "$1" in
    --limit) limit="${2:-20}"; shift 2 ;;
    --query|--type) query="${2:-}"; shift 2 ;;
    --cross-project) shift ;;
    *) shift ;;
  esac
done

eval "$("$(dirname "$0")/robobuilder-slug")"
state_root="${ROBOBUILDER_HOME:-$HOME/.robobuilder}"
file="$state_root/projects/${SLUG:-unknown}/learnings.jsonl"

if [ ! -s "$file" ]; then
  echo "No learnings yet."
  exit 0
fi

if [ -n "$query" ]; then
  grep -i -- "$query" "$file" 2>/dev/null | tail -n "$limit" || echo "No matches."
else
  tail -n "$limit" "$file"
fi
